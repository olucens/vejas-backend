# Server
PORT=3000
CORS_ORIGIN=http://localhost:4200

# Postgres (docker compose service "db"; localhost when running app on host)
POSTGRES_USER=admin
POSTGRES_PASSWORD=changeme
POSTGRES_DB=vejas_db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://admin:changeme@localhost:5432/vejas_db?schema=public

# Redis
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Auth
CRYPT_SALT=10
JWT_SECRET_KEY=dev-secret-change-me-in-prod
JWT_SECRET_REFRESH_KEY=dev-refresh-secret-change-me-in-prod
TOKEN_EXPIRE_TIME=1h
TOKEN_REFRESH_EXPIRE_TIME=24h

# Logging
LOG_LEVEL=2
LOG_DIR=logs
